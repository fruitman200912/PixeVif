# PostgreSQL (matches docker-compose.yml service defaults)
# NOTE: host port is 5433, not the default 5432 — kept clear of a locally
# installed Postgres that may already be listening on 5432.
DATABASE_URL="postgresql://pixelvif:pixelvif@localhost:5433/pixelvif?schema=public"

# Redis
# NOTE: host port is 6380, not the default 6379, for the same reason.
REDIS_URL="redis://localhost:6380"

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN="http://localhost:1420"

# Auth
JWT_SECRET="replace-with-a-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-random-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# AI
STABILITY_API_KEY="replace-with-your-stability-ai-key"
